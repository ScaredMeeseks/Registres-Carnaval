// ============================================================
// Firestore Security Rules
// ============================================================
// Deployed from the repo (source of truth):
//   firebase deploy --only firestore:rules,storage
// Do NOT edit rules directly in the Firebase Console.
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin emails (hardcoded)
    function isAdmin() {
      return request.auth != null &&
        (request.auth.token.email == 'marna96@gmail.com' ||
         request.auth.token.email == 'said@magmamedia.cat');
    }

    // Caps docs are keyed by email: caps/{email}
    function capOwnsColla(collaId) {
      return request.auth != null &&
        request.auth.token.email in
          get(/databases/$(database)/documents/colles/$(collaId)).data.capEmails;
    }

    // Admins collection — each user may read their own doc (login routing)
    match /admins/{email} {
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    // Caps de colla — doc ID is the cap's email
    match /caps/{email} {
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    // Colles — public read (landing page validates the 6-char code)
    match /colles/{collaId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Assigned caps may only change the T&C document fields
      allow update: if isAdmin() ||
        (request.auth != null &&
         request.auth.token.email in resource.data.capEmails &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pdfUrl', 'pdfName']));
    }

    // Registrations — created anonymously in a single write after T&C
    // acceptance; managed only by admins and the owning colla's caps
    match /registrations/{regId} {
      allow create: if request.resource.data.keys().hasAll(
          ['name', 'surname', 'idNumber', 'email', 'phone',
           'collaCode', 'collaName', 'collaId', 'tcAccepted', 'timestamp'])
        && request.resource.data.keys().hasOnly(
          ['name', 'surname', 'idNumber', 'email', 'phone',
           'collaCode', 'collaName', 'collaId', 'tcAccepted', 'timestamp'])
        && request.resource.data.tcAccepted == true
        && request.resource.data.collaId is string
        && exists(/databases/$(database)/documents/colles/$(request.resource.data.collaId));
      allow read, update, delete: if isAdmin() || capOwnsColla(resource.data.collaId);
    }

    // Services — catalog of orderable items, managed by admins
    match /services/{serviceId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Orders — supply orders placed by caps for their own colla
    match /orders/{orderId} {
      allow create: if (isAdmin() ||
          (capOwnsColla(request.resource.data.collaId) &&
           request.resource.data.capEmail == request.auth.token.email))
        && request.resource.data.keys().hasAll(
          ['collaId', 'collaCode', 'collaName', 'capEmail', 'items', 'total', 'createdAt', 'updatedAt'])
        && request.resource.data.keys().hasOnly(
          ['collaId', 'collaCode', 'collaName', 'capEmail', 'items', 'total', 'createdAt', 'updatedAt'])
        && request.resource.data.items is list
        && request.resource.data.total is number;
      allow read, delete: if isAdmin() || capOwnsColla(resource.data.collaId);
      // Orders can't be moved to another colla
      allow update: if (isAdmin() || capOwnsColla(resource.data.collaId))
        && request.resource.data.collaId == resource.data.collaId;
    }

    // Meta — migration markers etc.
    match /meta/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
