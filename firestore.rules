// ============================================================
// Firestore Security Rules
// ============================================================
// Deployed from the repo (source of truth):
//   firebase deploy --only firestore:rules,storage
// Do NOT edit rules directly in the Firebase Console.
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin emails (hardcoded)
    function isAdmin() {
      return request.auth != null &&
        (request.auth.token.email == 'marna96@gmail.com' ||
         request.auth.token.email == 'said@magmamedia.cat');
    }

    // Caps docs are keyed by email: caps/{email}
    function capOwnsColla(collaId) {
      return request.auth != null &&
        request.auth.token.email in
          get(/databases/$(database)/documents/colles/$(collaId)).data.capEmails;
    }

    // Normal users have a users/{email} profile pointing at their colla.
    // Works for list queries only because clients filter where('collaId','==',…)
    function isMemberOfColla(collaId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.collaId == collaId;
    }

    // Admins collection — each user may read their own doc (login routing)
    match /admins/{email} {
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    // Caps de colla — doc ID is the cap's email
    match /caps/{email} {
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    // Member profiles — doc ID is the member's email. Created at signup
    // (or backfilled by migration v2 from legacy registrations). Only
    // name/colla data lives here; DNI/phone stay in registrations.
    // tcPending marks members who registered before their colla published
    // its T&C — they are prompted to accept at login.
    match /users/{email} {
      allow create: if (isAdmin() ||
          (request.auth != null && request.auth.token.email == email))
        && request.resource.data.email == email
        && request.resource.data.keys().hasAll(
          ['email', 'name', 'surname', 'collaId', 'collaCode', 'collaName', 'regId', 'createdAt'])
        && request.resource.data.keys().hasOnly(
          ['email', 'name', 'surname', 'collaId', 'collaCode', 'collaName', 'regId', 'createdAt', 'tcPending'])
        && request.resource.data.collaId is string
        && exists(/databases/$(database)/documents/colles/$(request.resource.data.collaId));
      allow read: if isAdmin()
        || (request.auth != null && request.auth.token.email == email)
        || capOwnsColla(resource.data.collaId)
        || isMemberOfColla(resource.data.collaId);
      // Users may refresh their own profile but never switch colla
      allow update: if isAdmin() ||
        (request.auth != null && request.auth.token.email == email
         && request.resource.data.collaId == resource.data.collaId
         && request.resource.data.keys().hasOnly(
          ['email', 'name', 'surname', 'collaId', 'collaCode', 'collaName', 'regId', 'createdAt', 'tcPending']));
      allow delete: if isAdmin() || capOwnsColla(resource.data.collaId);
    }

    // Colles — public read (landing page validates the 6-char code)
    match /colles/{collaId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Assigned caps may only change the T&C document fields
      allow update: if isAdmin() ||
        (request.auth != null &&
         request.auth.token.email in resource.data.capEmails &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pdfUrl', 'pdfName']));
    }

    // Registrations — created by the participant's own account in a single
    // write; tcAccepted may be false only while the colla has not published
    // its T&C (the member accepts later, at login). Managed by admins and
    // the owning colla's caps.
    match /registrations/{regId} {
      allow create: if request.auth != null
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.keys().hasAll(
          ['name', 'surname', 'idNumber', 'email', 'phone',
           'collaCode', 'collaName', 'collaId', 'tcAccepted', 'timestamp'])
        && request.resource.data.keys().hasOnly(
          ['name', 'surname', 'idNumber', 'email', 'phone',
           'collaCode', 'collaName', 'collaId', 'tcAccepted', 'timestamp'])
        && request.resource.data.tcAccepted is bool
        && request.resource.data.collaId is string
        && exists(/databases/$(database)/documents/colles/$(request.resource.data.collaId))
        && (request.resource.data.tcAccepted == true
            || !('pdfUrl' in get(/databases/$(database)/documents/colles/$(request.resource.data.collaId)).data));
      allow read, delete: if isAdmin() || capOwnsColla(resource.data.collaId);
      // Members may flip their own pending T&C acceptance to true — nothing else
      allow update: if isAdmin() || capOwnsColla(resource.data.collaId)
        || (request.auth != null
            && request.auth.token.email == resource.data.email
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tcAccepted'])
            && request.resource.data.tcAccepted == true);
    }

    // Services — catalog of orderable items, managed by admins
    match /services/{serviceId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Orders — supply orders placed by caps for their own colla
    match /orders/{orderId} {
      allow create: if (isAdmin() ||
          (capOwnsColla(request.resource.data.collaId) &&
           request.resource.data.capEmail == request.auth.token.email))
        && request.resource.data.keys().hasAll(
          ['collaId', 'collaCode', 'collaName', 'capEmail', 'items', 'total', 'createdAt', 'updatedAt'])
        && request.resource.data.keys().hasOnly(
          ['collaId', 'collaCode', 'collaName', 'capEmail', 'items', 'total', 'createdAt', 'updatedAt'])
        && request.resource.data.items is list
        && request.resource.data.total is number;
      allow read, delete: if isAdmin() || capOwnsColla(resource.data.collaId);
      // Orders can't be moved to another colla
      allow update: if (isAdmin() || capOwnsColla(resource.data.collaId))
        && request.resource.data.collaId == resource.data.collaId;
    }

    // Posts — colla-page content published by caps (messages/links/images)
    match /posts/{postId} {
      allow create: if (isAdmin() || capOwnsColla(request.resource.data.collaId))
        && request.resource.data.authorEmail == request.auth.token.email
        && request.resource.data.keys().hasAll(
          ['collaId', 'title', 'authorEmail', 'createdAt'])
        && request.resource.data.keys().hasOnly(
          ['collaId', 'title', 'body', 'url', 'authorEmail', 'createdAt',
           'pinned', 'imageUrl', 'imagePath']);
      allow read: if isAdmin()
        || capOwnsColla(resource.data.collaId)
        || isMemberOfColla(resource.data.collaId);
      // Posts can't be moved to another colla
      allow update: if (isAdmin() || capOwnsColla(resource.data.collaId))
        && request.resource.data.collaId == resource.data.collaId;
      allow delete: if isAdmin() || capOwnsColla(resource.data.collaId);
    }

    // Meta — migration markers etc.
    match /meta/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
