// ============================================================
// Firestore Security Rules
// ============================================================
// Copy and paste these rules into your Firebase Console:
// Firestore Database → Rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin emails (hardcoded)
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'marna96@gmail.com' || 
         request.auth.token.email == 'said@magmamedia.cat');
    }

    // Check if user is a cap de colla
    function isCap() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/caps/$(request.auth.token.email));
    }

    // Admins collection — only admins can read
    match /admins/{email} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Caps de colla collection
    match /caps/{capId} {
      // Admins can read/write; caps can read their own
      allow read: if isAdmin() || 
        (request.auth != null && resource.data.email == request.auth.token.email);
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Colles collection
    match /colles/{collaId} {
      // Anyone can read (needed for code validation on landing page)
      allow read: if true;
      // Only admins can create/delete; admins and authenticated caps can update (for PDF upload)
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || request.auth != null;
    }

    // Registrations collection
    match /registrations/{regId} {
      // Anyone can create (public registration)
      allow create: if true;
      // Anyone can update tcAccepted field (for the T&C step)
      allow update: if true;
      // Admins can read all; caps can read their colla's registrations
      allow read: if isAdmin() || request.auth != null;
      // Admins and authenticated users (caps) can delete
      allow delete: if isAdmin() || request.auth != null;
    }
  }
}
